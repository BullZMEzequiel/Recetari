<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".RecetarioApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RecetarioBoliviano"
        tools:targetApi="31">

        <activity
            android:name=".vista.actividades.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.RecetarioBoliviano" />

        <!-- SplashActivity como launcher -->
        <activity
            android:name=".vista.actividades.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.RecetarioBoliviano.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".vista.actividades.RegistroActivity"
            android:exported="false"
            android:theme="@style/Theme.RecetarioBoliviano" />

        <activity
            android:name=".vista.actividades.RecetaFormActivity"
            android:exported="false"
            android:theme="@style/Theme.RecetarioBoliviano"
            android:parentActivityName=".vista.actividades.MainActivity" />

        <activity
            android:name=".vista.actividades.RecetaDetalleActivity"
            android:exported="false"
            android:theme="@style/Theme.RecetarioBoliviano"
            android:parentActivityName=".vista.actividades.MainActivity" />

        <activity
            android:name=".vista.actividades.PerfilActivity"
            android:exported="false"
            android:theme="@style/Theme.RecetarioBoliviano"
            android:parentActivityName=".vista.actividades.MainActivity" />

        <activity
            android:name=".vista.actividades.RecetasDepartamentoActivity"
            android:exported="false"
            android:theme="@style/Theme.RecetarioBoliviano"
            android:parentActivityName=".vista.actividades.MainActivity" />

        <activity
            android:name=".vista.actividades.CarpetasActivity"
            android:exported="false"
            android:theme="@style/Theme.RecetarioBoliviano"
            android:parentActivityName=".vista.actividades.MainActivity" />

        <activity
            android:name=".vista.actividades.RecetasCarpetaActivity"
            android:exported="false"
            android:theme="@style/Theme.RecetarioBoliviano"
            android:parentActivityName=".vista.actividades.CarpetasActivity" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>